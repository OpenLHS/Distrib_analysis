write.csv(sumWExpGlobal, file = paste0("sumWExpGlobal_output_", t-1, ".csv"), row.names = FALSE)
write.csv(as.data.frame(xbarri), file = paste0("xbarri_", t-1, ".csv"), quote = FALSE, row.names = FALSE)
