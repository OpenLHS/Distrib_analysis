DDk <- as.vector(read.csv(paste0("DD", i, "_output_", t-3, ".csv"))[,1])
RobustSE2 <- RobustSE2 + DDk
#        DD <- DD + DDk
}
RobustSE <- sqrt(RobustSE2)
# Create output
oldBeta <- read.csv(paste0("Beta_", t-3, "_output.csv"))
